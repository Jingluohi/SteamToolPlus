                                    <TextBlock Text="格式：LEADERBOARD_NAME=排序方式 (0-2)=显示类型 (0-3)" Foreground="#FFB4BED6" FontSize="13"/>
                                    <TextBlock Text="排序：0=无 1=升序 2=降序 | 显示：0=无 1=数字 2=秒 3=毫秒" Foreground="#FFB4BED6" FontSize="13"/>
                                    <TextBox x:Name="TxtLeaderboards" Height="70" AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,5,0,0"/>
                                </StackPanel>
                            </GroupBox>
                            
                            <Button Content="⚡ 一键配置成就统计" Background="#FF0099F2" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="13" FontWeight="Bold"
                                    Padding="12,6" Margin="0,15,0,0"
                                    Cursor="Hand" BorderThickness="0" Click="OneClickAchievementConfig_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="PatchAdvancedPanel" Visibility="Collapsed">
                            <TextBlock Text="🔧 高级功能配置" FontSize="13" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,10"/>

                            <GroupBox Header="SteamHTTP模拟配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableHttp" Content="启用 SteamHTTP 模拟" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="HTTP 模拟目录：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtHttpFolder" Grid.Column="0" Padding="3" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Cursor="Hand" BorderThickness="0" Click="SelectHttpFolder_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="说明：在steam_settings/http/目录下创建域名+路径文件夹，可模拟Steam API响应" Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="头像配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableAvatar" Content="使用自定义头像" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="头像文件 (png/jpg)：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtAvatarPath" Grid.Column="0" Padding="3" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Cursor="Hand" BorderThickness="0" Click="SelectAvatarFile_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="说明：头像文件放在GSE Saves/settings/或游戏steam_settings/目录下" Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="语言配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableLanguage" Content="自定义支持语言列表" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="语言代码（一行一个，如：schinese, english, japanese）：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <TextBox x:Name="TxtLanguages" Height="50" AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                    <TextBlock Text="代码：arabic, bulgarian, schinese, tchinese, czech, danish, dutch, english, finnish, french, german..." Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Mods模组配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableMods" Content="启用 Mods 模组支持" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="Mods 目录：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtModsFolder" Grid.Column="0" Padding="3" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Cursor="Hand" BorderThickness="0" Click="SelectModsFolder_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="说明：在steam_settings/mods/目录下按编号创建子文件夹，放入mod文件" Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="手柄配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableController" Content="启用XInput手柄支持" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="Action Set配置文件（steam_settings/controller/目录）：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <TextBox x:Name="TxtControllerConfig" Height="50" AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                    <TextBlock Text="按钮：A,B,X,Y,START,BACK,LSTICK,RSTICK,LBUMPER,RBUMPER,DLTRIGGER,DRTRIGGER等" Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="授权Token配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableTicket" Content="启用EncryptedAppTicket" Foreground="#FFB4BED6"/>
                                    <TextBlock Text="Base64编码的Ticket：" Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                    <TextBox x:Name="TxtTicket" Height="40" AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                    <TextBlock Text="说明：用于需要特定ticket格式的应用，可从真实Steam客户端获取" Foreground="#FFB4BED6" FontSize="13"/>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock Text="💡 提示：高级功能通常用于特殊游戏需求，普通游戏使用基础配置即可"
                                       Foreground="#FFF57C00" FontSize="13" Margin="0,10,0,0"/>
                            
                            <Button Content="⚡ 一键配置高级功能" Background="#FF0099F2" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="13" FontWeight="Bold"
                                    Padding="12,6" Margin="0,15,0,0"
                                    Cursor="Hand" BorderThickness="0" Click="OneClickAdvancedConfig_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>