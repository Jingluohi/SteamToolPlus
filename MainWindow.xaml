                        <Border Grid.Row="0" Background="#FF1A2445" Padding="15,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 返回按钮 -->
                                <Button Grid.Column="0" Content="← 返回"
                                Background="#FF0099F2" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="10,5" Margin="0,0,15,0"
                                Cursor="Hand" BorderThickness="0"
                                Click="BtnBackToList_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 游戏标题 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TxtDetailGameName" Text="游戏名称" FontSize="19" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtDetailGameNameCn" Text="" FontSize="16" Foreground="#FF909BB8"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtDetailGameId" Text="Game ID: 000000" FontSize="13" Foreground="#FFB4BED6" Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- 还原游戏和注入按钮（右上角） -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <!-- 还原游戏按钮 -->
                                    <Button x:Name="BtnRestoreGame" 
                                    Content="🔄 还原游戏" 
                                    Background="#FFF57C00" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="16" FontWeight="Bold"
                                    Padding="30,12" Margin="0,0,10,0"
                                    Cursor="Hand" BorderThickness="0"
                                    IsEnabled="False"
                                    Click="BtnRestoreGame_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FFE65100"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#FF3C4A5C"/>
                                                        <Setter Property="Foreground" Value="#FF909BB8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- 注入补丁按钮 -->
                                    <Button Grid.Column="2" x:Name="BtnInjectPatch" 
                                    Content="💉 注入补丁" 
                                    Background="#FF2E7D32" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="16" FontWeight="Bold"
                                    Padding="30,12" 
                                    Cursor="Hand" BorderThickness="0"
                                    IsEnabled="False"
                                    Click="BtnInjectPatch_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF1B5E20"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#FF3C4A5C"/>
                                                        <Setter Property="Foreground" Value="#FF909BB8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 游戏封面和路径选择 -->
                        <Border Grid.Row="1" Background="#FF1A2445" Padding="15,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 游戏封面 -->
                                <Border Grid.Column="0" Width="200" Height="300" Background="#FF111930" CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Left">
                                    <Image x:Name="ImgDetailCover" Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- 路径选择区域 -->
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="选择游戏安装路径：" FontSize="14" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtGamePath" Grid.Column="0" 
                                         Background="#FF202D55" Foreground="White"
                                         BorderBrush="#FF3C4A5C" BorderThickness="1"
                                         Padding="10,8" FontSize="13"
                                         VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="浏览文件夹"
                                        Background="#FF0099F2" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="13"
                                        Padding="10,6" Margin="10,0,0,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnSelectGamePath_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="TxtPathHint" 
                                       Text="💡 提示：请选择游戏的安装文件夹，补丁文件将被复制到此目录" 
                                       FontSize="13" Foreground="#FFF57C00" 
                                       Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 补丁信息 -->
                        <Border Grid.Row="2" Background="#FF1A2445" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="补丁文件信息" FontSize="16" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,15"/>

                                <!-- 补丁文件列表 -->
                                <Border Background="#FF111930" CornerRadius="8" Padding="15" Margin="0,0,0,20" MinHeight="150">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="即将复制的补丁文件：" FontSize="13" FontWeight="Bold" Foreground="#FFB4BED6" Margin="0,0,0,10"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                            <StackPanel x:Name="PatchFilesList">
                                                <!-- 补丁文件列表将在这里动态生成 -->
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- 进度和日志 -->
                                <Border x:Name="InjectProgressPanel" Background="#FF111930" CornerRadius="8" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TxtInjectStatus" Grid.Column="0" Text="准备中..." FontSize="13" Foreground="#FFB4BED6"/>
                                            <TextBlock x:Name="TxtInjectProgress" Grid.Column="1" Text="0/0" FontSize="13" Foreground="#FFFFFFFF"/>
                                        </Grid>
                                        <ProgressBar x:Name="InjectProgressBar" Height="20" Background="#FF0A0F20" Foreground="#FF0099F2" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150" Margin="0,10,0,0">
                                            <TextBox x:Name="TxtInjectLog" 
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#FF0A0F20"
                                             Foreground="#FFB4BED6"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             BorderThickness="0"
                                             Padding="5"
                                             MinHeight="80"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- 游戏本体下载界面 -->
            <Grid x:Name="DownloadPanel" Visibility="Collapsed" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标签页切换按钮 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="BtnTabManifest" Content="📦 通过清单下载" 
                            Background="#FF0099F2" Foreground="White"
                            FontFamily="微软雅黑" FontSize="13" FontWeight="Bold"
                            Padding="20,8" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0"
                            Click="TabManifest_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnTabCloudDrive" Content="☁️ 网盘下载（解压即玩）" 
                            Background="#FF1A2445" Foreground="#FFB4BED6"
                            FontFamily="微软雅黑" FontSize="13"
                            Padding="20,8" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0"
                            Click="TabCloudDrive_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- 通过清单下载内容 -->
                <Grid x:Name="ManifestDownloadContent" Grid.Row="1" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                <!-- 右上角 ManifestHub 按钮（使用 Canvas 绝对定位，不破坏原有布局） -->
                <Canvas Grid.Row="0" Height="0">
                    <Button Content="🔗 ManifestHub" Canvas.Right="10" Canvas.Top="-35"
                            Background="#FF0D1326" Foreground="#FF64B8FF"
                            FontFamily="微软雅黑" FontSize="13" Padding="10,3"
                            Cursor="Hand" BorderThickness="0" Click="OpenManifestHub_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Canvas>
                <GroupBox Grid.Row="0" Header="第一步：路径配置" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                       

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="1. 选择ddv20.exe程序：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="13"/>
                        <TextBox x:Name="TxtDdExePath" Grid.Row="0" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectDdExe_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="2. 选择游戏清单文件夹：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="13"/>
                        <TextBox x:Name="TxtGameConfigDir" Grid.Row="1" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectGameConfigDir_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="3. 游戏保存目录：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="13"/>
                        <TextBox x:Name="TxtSaveDir" Grid.Row="2" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="13" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectSaveDir_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="第二步：游戏信息确认" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,8" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="TxtGameInfo" Text="游戏名称：未加载 | AppID：未加载 | 可下载 Depot 数量：0 个"
                                   Foreground="#FFB4BED6" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnStartDownload" Content="▶ 开始下载" Background="#FF2E7D32" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="13" FontWeight="Bold"
                                    Padding="15,6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0" IsEnabled="False" Click="StartDownload_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnPauseDownload" Content="⏸ 暂停下载" Background="#FFF57C00" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="13"
                                    Padding="15,6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0" IsEnabled="False" Click="PauseResumeDownload_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="下载日志" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,0" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FF0A0F20">
                        <TextBox x:Name="TxtDownloadLog"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#FF0A0F20"
                                 Foreground="#FFB4BED6"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 BorderThickness="0"
                                 Padding="5"/>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <!-- 网盘下载（解压即玩）内容 -->
            <Grid x:Name="CloudDriveDownloadContent" Grid.Row="1" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="☁️ 网盘下载功能即将上线" 
                               FontSize="19" FontWeight="Bold" Foreground="#FFB4BED6" 
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="敬请期待..." 
                               FontSize="14" Foreground="#FF64B8FF" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="PatchPanel" Visibility="Collapsed" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF1A2445" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnBasic" Content="⚙️ 基础配置"
                                Background="#FF0099F2" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="basic">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnSave" Content="💾 存档配置"
                                Background="#FF2E7D32" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="save">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnNetwork" Content="🌐 局域网联机"
                                Background="#FFF57C00" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="network">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAchievement" Content="🏆 成就统计"
                                Background="#FF9C27B0" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="achievement">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAdvanced" Content="🔧 高级功能"
                                Background="#FF455A64" Foreground="White"
                                FontFamily="微软雅黑" FontSize="13"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="advanced">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#FF1A2445" Padding="5">
                    <Grid x:Name="PatchContentPanel">
                        <StackPanel x:Name="PatchBasicPanel" Visibility="Visible">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="🔧 基础配置" FontSize="13" FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                <Button Content="📦 跳转SteamDB" HorizontalAlignment="Right"
                                        Background="#FF0D1326" Foreground="#FF64B8FF"
                                        FontFamily="微软雅黑" FontSize="13" Padding="10,3"
                                        Cursor="Hand" BorderThickness="0" Click="OpenSteamDB_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DockPanel>

                            <GroupBox Header="模拟器模式选择（必选）" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <RadioButton x:Name="RbNormalMode" Content="常规模式（推荐，替换steam_api.dll）"
                                                IsChecked="True" GroupName="EmulatorMode" Foreground="#FFB4BED6" Margin="0,2"/>
                                    <RadioButton x:Name="RbExperimentalMode" Content="实验版模式（替换steamclient.dll）"
                                                GroupName="EmulatorMode" Foreground="#FFB4BED6" Margin="0,2"/>
                                    <TextBlock x:Name="TxtModeTip" Text="常规模式：适用于90%以上的Steam游戏，替换steam_api.dll即可生效"
                                               Foreground="#FFB4BED6" FontSize="13" Margin="0,5,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Overlay覆盖层配置（Shift+Tab弹出）" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
