{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Game",
    "copyright": "© 2024 Steam Tool Plus",
    "targets": ["nsis"],
    "externalBin": [],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Steam/Xbox 风格游戏管理工具",
    "shortDescription": "游戏管理工具"
  },
  "productName": "Steam Tool Plus",
  "version": "1.0.0",
  "identifier": "com.steamtoolplus.app",
  "plugins": {},
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Steam Tool Plus",
        "width": 1450,
        "minWidth": 1450,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ]
  }
}
