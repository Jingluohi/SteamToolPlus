{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Tool Plus",
  "version": "1.20.0",
  "identifier": "com.steamtoolplus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Tool Plus",
        "width": 1500,
        "height": 900,
        "minWidth": 1500,
        "minHeight": 900,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": true,
        "fullscreen": false,
        "focus": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' blob: data: asset: http://asset.localhost",
        "font-src": "'self'",
        "connect-src": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": ["default"]
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": false
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
