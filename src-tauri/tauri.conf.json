{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Tool Plus",
  "version": "1.25.2",
  "identifier": "com.steamtoolplus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Tool Plus",
        "width": 1530,
        "height": 920,
        "minWidth": 1540,
        "minHeight": 920,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": true,
        "fullscreen": false,
        "focus": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' blob: data: asset: http://asset.localhost",
        "font-src": "'self'",
        "connect-src": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": ["default"]
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}