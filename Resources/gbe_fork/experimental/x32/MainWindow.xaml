                                                <StackPanel>
                                                    <TextBlock Text="文件结构示例：" FontSize="12" Foreground="#FFB4BED6" FontWeight="Bold"/>
                                                    <TextBlock FontSize="11" Foreground="#FF64B8FF" FontFamily="Consolas" Margin="0,3,0,0" TextWrapping="Wrap" xml:space="preserve">{
  "achievements": [
    {
      "name": "ACH_FIRST_WIN",
