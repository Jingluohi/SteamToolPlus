<!--
界面布局：
- 左侧：功能选择面板
- 右侧：内容区域（下载、补丁、教程）
-->
<Window x:Class="SteamCrackTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SteamCrackTool | 作者：鲸落_hi"
        Height="900" Width="1400"
        MinHeight="650" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        FontFamily="微软雅黑"
        Background="#FF111930"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <!-- 标题栏渐变背景色 -->
            <ControlTemplate.Resources>
                <LinearGradientBrush x:Key="TitleBarGradient" StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF0D1326" Offset="0"/>
                    <GradientStop Color="#FF1A2744" Offset="0.5"/>
                    <GradientStop Color="#FF0D1326" Offset="1"/>
                </LinearGradientBrush>
                <LinearGradientBrush x:Key="TitleBtnHoverGradient" StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF3A4565" Offset="0"/>
                    <GradientStop Color="#FF2A3448" Offset="1"/>
                </LinearGradientBrush>
            </ControlTemplate.Resources>
            <Border Background="#FF111930" CornerRadius="8" BorderBrush="#FF3C4A5C" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5" Color="#FF000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 自定义标题栏 -->
                    <Border Grid.Row="0" Background="{StaticResource TitleBarGradient}" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 程序图标和标题 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" ClipToBounds="True">
                                    <Image Source="Resources/icon.jpg" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="SteamCrackTool" Foreground="#FFFFFFFF" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBlock Text=" | 作者：鲸落_hi" Foreground="#FF7A8BA8" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <!-- 窗口控制按钮 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                <!-- 最小化按钮 -->
                                <Button Width="46" Height="30" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Click="MinimizeBtn_Click" ToolTip="最小化">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="4">
                                                <Path Data="M0,0 L8,0" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" 
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      SnapsToDevicePixels="True"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF3C4A5C"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF2D3A4D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="#FFB4BED6"/>
                                    </Button.Foreground>
                                </Button>

                                <!-- 最大化按钮 -->
                                <Button Width="46" Height="30" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Click="MaximizeBtn_Click" ToolTip="最大化">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="4">
                                                <Path Data="M1,1 L7,1 L7,7 L1,7 Z" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" 
                                                      Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      SnapsToDevicePixels="True"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF3C4A5C"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF2D3A4D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="#FFB4BED6"/>
                                    </Button.Foreground>
                                </Button>

                                <!-- 关闭按钮 -->
                                <Button Width="46" Height="30" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Click="CloseBtn_Click" ToolTip="关闭">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="4">
                                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Path Data="M0,0 L8,8" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                                    <Path Data="M8,0 L0,8" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FFE81123"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FFC4101F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="#FFB4BED6"/>
                                    </Button.Foreground>
                                </Button>
                            </StackPanel>
                            <!-- 标题栏底部高亮分隔线 -->
                            <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="2" Background="#FF0099F2" Opacity="0.8"/>
                        </Grid>
                    </Border>
                    <!-- 内容区域 -->
                    <Border Grid.Row="1" Background="#FF111930" CornerRadius="0,0,8,8">
                        <ContentPresenter/>
                    </Border>
                </Grid>
            </Border>
        </ControlTemplate>
    </Window.Template>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="193.5"/>
            <ColumnDefinition Width="26.5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FF0D1326" Grid.ColumnSpan="2">
            <DockPanel>
                <!-- 顶部标题区 -->

                <!-- 底部信息链接区 -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="0,0,0,15">
                    <Border Height="1" Background="#FF3C4A5C" Margin="20,0"/>
                    <TextBlock Text="B 站 UP 主：鲸落_hi"
                               FontSize="12" Foreground="#FFB4BED6"
                               HorizontalAlignment="Left" Margin="20,15,20,2"/>
                    <TextBlock x:Name="BilibiliLink"
                               Text="跳转 B 站主页"
                               FontSize="12" Foreground="#FF909BB8"
                               TextDecorations="Underline" Cursor="Hand"
                               HorizontalAlignment="Left" Margin="20,2"
                               MouseLeftButtonDown="BilibiliLink_MouseLeftButtonDown"/>
                </StackPanel>

                <!-- 中部导航功能区 -->
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnPatchSpecial" Content="特定游戏补丁" Height="48"
                            Background="Transparent" Foreground="#FF909BB8"
                            FontFamily="微软雅黑" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Click="BtnPatchSpecial_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <Grid>
                                        <Border x:Name="highlightBar" Width="4" Background="#FF0099F2" 
                                                HorizontalAlignment="Left" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                            <Path Width="20" Height="20" Stretch="Uniform" 
                                                  Fill="{TemplateBinding Foreground}" 
                                                  Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                                  Margin="0,0,12,0"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFB4BED6"/>
                                        <Setter TargetName="border" Property="Background" Value="#FF152040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnPatch" Content="游戏补丁注入" Height="48"
                            Background="Transparent" Foreground="#FF909BB8"
                            FontFamily="微软雅黑" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Click="BtnPatch_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <Grid>
                                        <Border x:Name="highlightBar" Width="4" Background="#FF0099F2" 
                                                HorizontalAlignment="Left" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                            <Path Width="20" Height="20" Stretch="Uniform" 
                                                  Fill="{TemplateBinding Foreground}" 
                                                  Data="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"
                                                  Margin="0,0,12,0"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFB4BED6"/>
                                        <Setter TargetName="border" Property="Background" Value="#FF152040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnGameDownload" Content="游戏本体下载" Height="48"
                            Background="Transparent" Foreground="#FF909BB8"
                            FontFamily="微软雅黑" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Click="BtnGameDownload_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <Grid>
                                        <Border x:Name="highlightBar" Width="4" Background="#FF0099F2" 
                                                HorizontalAlignment="Left" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                            <Path Width="20" Height="20" Stretch="Uniform" 
                                                  Fill="{TemplateBinding Foreground}" 
                                                  Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                                  Margin="0,0,12,0"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFB4BED6"/>
                                        <Setter TargetName="border" Property="Background" Value="#FF152040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnTutorial" Content="工具使用教程" Height="48"
                            Background="Transparent" Foreground="#FF909BB8"
                            FontFamily="微软雅黑" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Click="BtnTutorial_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <Grid>
                                        <Border x:Name="highlightBar" Width="4" Background="#FF0099F2" 
                                                HorizontalAlignment="Left" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                            <Path Width="20" Height="20" Stretch="Uniform" 
                                                  Fill="{TemplateBinding Foreground}" 
                                                  Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                                  Margin="0,0,12,0"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFB4BED6"/>
                                        <Setter TargetName="border" Property="Background" Value="#FF152040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2" x:Name="ContentPanel" Background="#FF111930">
            <!-- 特定游戏补丁界面 -->
            <Grid x:Name="PatchSpecialPanel" Visibility="Visible" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题区 -->
                <Border Grid.Row="0" Background="#FF1A2445" Padding="15,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 标题 -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🎮 特定游戏补丁" FontSize="20" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,5"/>
                            <TextBlock Text="为特定游戏定制补丁配置" FontSize="12" Foreground="#FFB4BED6"/>
                        </StackPanel>

                        <!-- 搜索框 -->
                        <Border Grid.Column="1" Background="#FF3A4A7A" CornerRadius="6" Padding="8,4" MinWidth="250">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.3" Color="#FF000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 搜索输入框 -->
                                <TextBox x:Name="TxtGameSearch" 
                                         Grid.Column="0"
                                         Text="搜索游戏（名称或 ID）..."
                                         FontSize="13"
                                         Foreground="#FFB4BED6"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="5,4"
                                         VerticalAlignment="Center"
                                         GotFocus="TxtGameSearch_GotFocus"
                                         LostFocus="TxtGameSearch_LostFocus"
                                         TextChanged="TxtGameSearch_TextChanged">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="Transparent">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>

                                <!-- 搜索图标/按钮 -->
                                <Button x:Name="BtnSearch" 
                                        Grid.Column="1"
                                        Content="🔍"
                                        FontSize="16"
                                        Width="32" Height="32"
                                        Background="#FF0099F2"
                                        Foreground="White"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Click="BtnSearch_Click"
                                        Margin="4,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 内容区 -->
                <Border Grid.Row="1" Background="#FF1A2445" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 顶部工具栏 -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 分类标签页 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="BtnPatchTypeAll" Content="全部游戏" 
                                        Background="#FF0099F2" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="13"
                                        Padding="15,8" Margin="0,0,10,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnPatchTypeAll_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnPatchTypeNoSteam" Content="🚫 免 Steam 启动补丁" 
                                        Background="#FF1A2445" Foreground="#FFB4BED6"
                                        FontFamily="微软雅黑" FontSize="13"
                                        Padding="15,8" Margin="0,0,10,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnPatchTypeNoSteam_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF202D55"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnPatchTypeLAN" Content="🌐 局域网联机补丁" 
                                        Background="#FF1A2445" Foreground="#FFB4BED6"
                                        FontFamily="微软雅黑" FontSize="13"
                                        Padding="15,8" Margin="0,0,10,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnPatchTypeLAN_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF202D55"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnPatchTypeSteamOnline" Content="🌍 Steam 联机补丁" 
                                        Background="#FF1A2445" Foreground="#FFB4BED6"
                                        FontFamily="微软雅黑" FontSize="13"
                                        Padding="15,8"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnPatchTypeSteamOnline_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF202D55"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <!-- 右侧视图切换按钮 -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnGridView" Content="▦"
                                        Background="#FF0099F2" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="14"
                                        Width="32" Height="32" Margin="0,0,5,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnGridView_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnListView" Content="☰"
                                        Background="#FF1A2445" Foreground="#FFB4BED6"
                                        FontFamily="微软雅黑" FontSize="14"
                                        Width="32" Height="32"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnListView_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF202D55"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- 游戏卡片网格（网格视图） -->
                        <ScrollViewer Grid.Row="1" x:Name="GridViewScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ItemsControl x:Name="GameCardsPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="200" Height="260" Margin="0,0,15,15"
                                                Background="#FF202D55" CornerRadius="8"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                            <Setter Property="BorderBrush" Value="#FF0099F2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 游戏封面 -->
