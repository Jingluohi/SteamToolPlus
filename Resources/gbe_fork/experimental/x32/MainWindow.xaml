                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <!-- 局域网联机教程内容 -->
                        <StackPanel x:Name="NetworkTutorialPanel" Visibility="Collapsed">
                            <TextBlock Text="🌐 局域网联机 - 超级详细教程"
                                       FontSize="18" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,15"/>

                            <!-- 第一部分：什么是局域网联机 -->
                            <GroupBox Header="📚 第一部分：什么是局域网联机？" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="12" Margin="0,8">
                                <StackPanel>
                                    <TextBlock Text="局域网联机（LAN Multiplayer）是指在同一网络内的多台电脑之间进行游戏联机。通过 Goldberg Emulator 的局域网模拟功能，可以让支持 Steam 联机的游戏在局域网内运行。" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="🎯 局域网联机的特点：" FontWeight="Bold" Foreground="#FF64B8FF" FontSize="13" Margin="0,0,0,5"/>
                                            <TextBlock Text="✓ 不需要互联网连接&#x0a;✓ 低延迟，联机流畅&#x0a;✓ 适合本地多人游戏&#x0a;✓ 支持的游戏有限（需要游戏本身支持 Steam 联机）" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF111930" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                                        <TextBlock Text="⚠️ 重要提示：&#x0a;• 不是所有游戏都支持局域网联机&#x0a;• 需要游戏本身支持 Steam 多人模式&#x0a;• 所有参与联机的电脑都需要安装相同的补丁&#x0a;• 游戏版本必须一致" FontSize="12" Foreground="#FFF57C00" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <!-- 第二部分：联机前的准备工作 -->
                            <GroupBox Header="📋 第二部分：联机前的准备工作" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="12" Margin="0,8">
                                <StackPanel>
                                    <TextBlock Text="在开始局域网联机之前，需要完成以下准备：" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="✅ 硬件和网络要求：" FontWeight="Bold" Foreground="#FF4CAF50" FontSize="13" Margin="0,0,0,5"/>
                                            <TextBlock Text="• 所有电脑连接到同一路由器或交换机&#x0a;• 建议使用有线网络（更稳定）&#x0a;• 确保所有电脑在同一网段（如 192.168.1.x）" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>

                                            <Border Background="#FF111930" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="📋 检查网络是否连通：" FontSize="12" Foreground="#FFB4BED6"/>
                                                    <TextBlock Text="1. 按 Win+R，输入 cmd，回车&#x0a;2. 输入 ping 192.168.1.xxx（对方 IP）&#x0a;3. 如果有回复，说明网络连通" FontSize="12" Foreground="#FF64B8FF" FontFamily="Consolas" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="💿 游戏和补丁要求：" FontWeight="Bold" Foreground="#FF4CAF50" FontSize="13" Margin="0,8,0,5"/>
                                            <TextBlock Text="• 所有电脑安装相同的游戏&#x0a;• 所有电脑安装 Goldberg Emulator 补丁&#x0a;• 游戏版本必须完全一致&#x0a;• AppID 必须相同" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="👥 人员要求：" FontWeight="Bold" Foreground="#FF4CAF50" FontSize="13" Margin="0,8,0,5"/>
                                            <TextBlock Text="• 至少 2 台电脑&#x0a;• 每台电脑至少 1 名玩家&#x0a;• 所有玩家使用不同的 Steam 账户（模拟的）" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <!-- 第三部分：详细配置步骤 -->
                            <GroupBox Header="📝 第三部分：详细配置步骤" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="12" Margin="0,8">
                                <StackPanel>
                                    <TextBlock Text="下面是详细的局域网联机配置步骤，跟着做一定能成功！" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <!-- 步骤 1 -->
                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="第 1 步：启用局域网联机" FontWeight="Bold" Foreground="#FF64B8FF" FontSize="13" Margin="0,0,0,8"/>
                                            <TextBlock Text="在局域网联机配置界面，勾选【启用局域网联机】选项。" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>

                                            <TextBlock Text="" FontSize="12"/>
                                            <TextBlock Text="✅ 操作方法：" FontSize="12" Foreground="#FF4CAF50" FontWeight="Bold" Margin="0,8,0,3"/>
                                            <TextBlock Text="直接勾选【启用局域网联机】复选框" FontSize="12" Foreground="#FFB4BED6"/>

                                            <Border Background="#FF111930" CornerRadius="4" Padding="8" Margin="0,8,0,0">
