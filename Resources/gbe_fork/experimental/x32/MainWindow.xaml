                                    <TextBlock Text="选择游戏安装路径：" FontSize="14" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtGamePath" Grid.Column="0" 
                                         Background="#FF202D55" Foreground="White"
                                         BorderBrush="#FF3C4A5C" BorderThickness="1"
                                         Padding="10,8" FontSize="13"
                                         VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="浏览文件夹"
                                        Background="#FF0099F2" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="12"
                                        Padding="10,6" Margin="10,0,0,0"
                                        Cursor="Hand" BorderThickness="0"
                                        Click="BtnSelectGamePath_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FF0078D4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="TxtPathHint" 
                                       Text="💡 提示：请选择游戏的安装文件夹，补丁文件将被复制到此目录" 
                                       FontSize="12" Foreground="#FFF57C00" 
                                       Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 补丁信息 -->
                        <Border Grid.Row="2" Background="#FF1A2445" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="补丁文件信息" FontSize="16" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,15"/>

                                <!-- 补丁文件列表 -->
                                <Border Background="#FF111930" CornerRadius="8" Padding="15" Margin="0,0,0,20" MinHeight="150">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="即将复制的补丁文件：" FontSize="13" FontWeight="Bold" Foreground="#FFB4BED6" Margin="0,0,0,10"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                            <StackPanel x:Name="PatchFilesList">
                                                <!-- 补丁文件列表将在这里动态生成 -->
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- 进度和日志 -->
                                <Border x:Name="InjectProgressPanel" Background="#FF111930" CornerRadius="8" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TxtInjectStatus" Grid.Column="0" Text="准备中..." FontSize="13" Foreground="#FFB4BED6"/>
                                            <TextBlock x:Name="TxtInjectProgress" Grid.Column="1" Text="0/0" FontSize="13" Foreground="#FFFFFFFF"/>
                                        </Grid>
                                        <ProgressBar x:Name="InjectProgressBar" Height="20" Background="#FF0A0F20" Foreground="#FF0099F2" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150" Margin="0,10,0,0">
                                            <TextBox x:Name="TxtInjectLog" 
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#FF0A0F20"
                                             Foreground="#FFB4BED6"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             BorderThickness="0"
                                             Padding="5"
                                             MinHeight="80"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- 游戏本体下载界面 -->
            <Grid x:Name="DownloadPanel" Visibility="Collapsed" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="第一步：路径配置" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="1. 选择ddv20.exe程序：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="12"/>
                        <TextBox x:Name="TxtDdExePath" Grid.Row="0" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="12" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectDdExe_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="2. 选择游戏清单文件夹：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="12"/>
                        <TextBox x:Name="TxtGameConfigDir" Grid.Row="1" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="12" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectGameConfigDir_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="3. 游戏保存目录：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="0,6" FontSize="12"/>
                        <TextBox x:Name="TxtSaveDir" Grid.Row="2" Grid.Column="1" Margin="8,6" Padding="4" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" BorderThickness="1"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="12" Padding="8,4" Margin="8,6,0,6" Cursor="Hand" BorderThickness="0" Click="SelectSaveDir_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="第二步：游戏信息确认" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,8" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="TxtGameInfo" Text="游戏名称：未加载 | AppID：未加载 | 可下载 Depot 数量：0 个"
                                   Foreground="#FFB4BED6" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnStartDownload" Content="▶ 开始下载" Background="#FF2E7D32" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="12" FontWeight="Bold"
                                    Padding="15,6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0" IsEnabled="False" Click="StartDownload_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnPauseDownload" Content="⏸ 暂停下载" Background="#FFF57C00" Foreground="White"
                                    FontFamily="微软雅黑" FontSize="12"
                                    Padding="15,6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0" IsEnabled="False" Click="PauseResumeDownload_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="下载日志" Foreground="#FFFFFFFF" Background="#FF1A2445" BorderBrush="#FF3C4A5C" Margin="0,0,0,0" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FF0A0F20">
                        <TextBox x:Name="TxtDownloadLog"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#FF0A0F20"
                                 Foreground="#FFB4BED6"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 BorderThickness="0"
                                 Padding="5"/>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <Grid x:Name="PatchPanel" Visibility="Collapsed" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF1A2445" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnBasic" Content="⚙️ 基础配置"
                                Background="#FF0099F2" Foreground="White"
                                FontFamily="微软雅黑" FontSize="12"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="basic">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnSave" Content="💾 存档配置"
                                Background="#FF2E7D32" Foreground="White"
                                FontFamily="微软雅黑" FontSize="12"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="save">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnNetwork" Content="🌐 局域网联机"
                                Background="#FFF57C00" Foreground="White"
                                FontFamily="微软雅黑" FontSize="12"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="network">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAchievement" Content="🏆 成就统计"
                                Background="#FF9C27B0" Foreground="White"
                                FontFamily="微软雅黑" FontSize="12"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="achievement">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAdvanced" Content="🔧 高级功能"
                                Background="#FF455A64" Foreground="White"
                                FontFamily="微软雅黑" FontSize="12"
                                Padding="12,8" Margin="3"
                                Cursor="Hand" BorderThickness="0"
                                Click="ShowPatchCategory_Click" Tag="advanced">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#FF1A2445" Padding="5">
                    <Grid x:Name="PatchContentPanel">
                        <StackPanel x:Name="PatchBasicPanel" Visibility="Visible">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="🔧 基础配置" FontSize="12" FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                <Button Content="📦 跳转SteamDB" HorizontalAlignment="Right"
                                        Background="#FF0D1326" Foreground="#FF64B8FF"
                                        FontFamily="微软雅黑" FontSize="12" Padding="10,3"
                                        Cursor="Hand" BorderThickness="0" Click="OpenSteamDB_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DockPanel>

                            <GroupBox Header="模拟器模式选择（必选）" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <RadioButton x:Name="RbNormalMode" Content="常规模式（推荐，替换steam_api.dll）"
                                                IsChecked="True" GroupName="EmulatorMode" Foreground="#FFB4BED6" Margin="0,2"/>
                                    <RadioButton x:Name="RbExperimentalMode" Content="实验版模式（替换steamclient.dll）"
                                                GroupName="EmulatorMode" Foreground="#FFB4BED6" Margin="0,2"/>
                                    <TextBlock x:Name="TxtModeTip" Text="常规模式：适用于90%以上的Steam游戏，替换steam_api.dll即可生效"
                                               Foreground="#FFB4BED6" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Overlay覆盖层配置（Shift+Tab弹出）" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <CheckBox x:Name="ChkEnableOverlay" Content="启用实验版Overlay覆盖层" Foreground="#FFB4BED6" Margin="0,2"/>
                                    <TextBlock Text="⚠️ 高度实验性功能，可能导致游戏崩溃" Foreground="#FFF44336" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="用户名：" Foreground="#FFB4BED6" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="TxtAccountName" Text="Player" Width="100" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                        <TextBlock Text="SteamID：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                                        <TextBox x:Name="TxtSteamId" Text="12345678901234567" Width="130" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <CheckBox x:Name="ChkAchievementSound" Content="成就音效" Foreground="#FFB4BED6" Margin="0,0,15,0"/>
                                        <CheckBox x:Name="ChkInviteSound" Content="邀请音效" Foreground="#FFB4BED6"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="路径配置" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="游戏目录：" Foreground="#FFB4BED6" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="TxtGameDir" Grid.Column="1" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,0,8,0"/>
                                        <Button Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="12" Padding="8,4" Cursor="Hand" BorderThickness="0" Click="SelectGameDir_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="游戏主程序：" Foreground="#FFB4BED6" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="TxtGameExePath" Grid.Column="1" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C" Margin="0,0,8,0"/>
                                        <Button Grid.Column="2" Content="浏览" Background="#FF0099F2" Foreground="White" FontFamily="微软雅黑" FontSize="12" Padding="8,4" Cursor="Hand" BorderThickness="0" Click="SelectGameExe_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="核心参数" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="Steam AppID：" Foreground="#FFB4BED6" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="TxtAppId" Width="90" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                        <TextBlock Text="DLC文件夹：" Foreground="#FFB4BED6" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12"/>
                                        <TextBox x:Name="TxtDlcFolder" Text="./" Width="90" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                        <TextBlock Text="例：./dlc" Foreground="#FFB4BED6" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkUnlockAllDlc" Content="一键解锁全部DLC（推荐）" IsChecked="True" Foreground="#FFB4BED6" Margin="0,5"/>
                                    <DockPanel Margin="0,5">
                                        <TextBlock Text="订阅组(AppPaths)：" Foreground="#FFB4BED6" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="TxtAppPaths" Width="280" Padding="3" FontSize="12" Background="#FF202D55" Foreground="White" BorderBrush="#FF3C4A5C"/>
                                        <TextBlock Text="格式：appid|路径" Foreground="#FFB4BED6" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </DockPanel>
                                </StackPanel>
                            </GroupBox>

                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Button Content="✅ 一键完成全部配置" Background="#FF0099F2" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="12" FontWeight="Bold"
                                        Padding="18,6" Margin="5" Cursor="Hand" BorderThickness="0" Click="RunFullConfig_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="🔓 全自动脱壳" Background="#FFF57C00" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="12"
                                        Padding="18,6" Margin="5" Cursor="Hand" BorderThickness="0" Click="RunSteamlessUnpack_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="清空日志" Background="#FF455A64" Foreground="White"
                                        FontFamily="微软雅黑" FontSize="12"
                                        Padding="10,6" Margin="5" Cursor="Hand" BorderThickness="0" Click="ClearPatchLog_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <GroupBox Header="操作日志" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="8" Margin="0,3">
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" Background="#FF111930">
                                    <TextBox x:Name="TxtPatchLog" IsReadOnly="True" TextWrapping="Wrap"
                                            AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                            Background="#FF111930" Foreground="#FFB4BED6"
                                            FontFamily="Consolas" FontSize="12" BorderThickness="0" Padding="3"/>
                                </ScrollViewer>
                            </GroupBox>
                        </StackPanel>

                        <StackPanel x:Name="PatchSavePanel" Visibility="Collapsed">
