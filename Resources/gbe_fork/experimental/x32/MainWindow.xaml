                            <!-- 第四部分：防火墙配置 -->
                            <GroupBox Header="🔥 第四部分：防火墙配置（重要）" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="12" Margin="0,8">
                                <StackPanel>
                                    <TextBlock Text="Windows 防火墙可能会阻止局域网联机，需要配置防火墙规则。" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="️ 方法 1：允许程序通过防火墙" FontWeight="Bold" Foreground="#FF64B8FF" FontSize="13" Margin="0,0,0,5"/>

                                            <Border Background="#FF111930" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="操作步骤：" FontSize="12" Foreground="#FFB4BED6" FontWeight="Bold"/>
                                                    <TextBlock Text="1. 打开控制面板 → Windows Defender 防火墙&#x0a;2. 点击&quot;允许应用或功能通过防火墙&quot;&#x0a;3. 点击&quot;更改设置&quot;&#x0a;4. 找到游戏主程序，勾选专用和公用&#x0a;5. 点击确定保存" FontSize="12" Foreground="#FF64B8FF" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text=" 方法 2：开放端口" FontWeight="Bold" Foreground="#FF64B8FF" FontSize="13" Margin="0,8,0,5"/>

                                            <Border Background="#FF111930" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="操作步骤：" FontSize="12" Foreground="#FFB4BED6" FontWeight="Bold"/>
                                                    <TextBlock Text="1. 打开控制面板 → Windows Defender 防火墙&#x0a;2. 点击&quot;高级设置&quot;&#x0a;3. 点击&quot;入站规则&quot; → &quot;新建规则&quot;&#x0a;4. 选择&quot;端口&quot; → 下一步&#x0a;5. 选择&quot;TCP&quot;，输入端口号（如 27015）&#x0a;6. 选择&quot;允许连接&quot;&#x0a;7. 勾选专用和公用&#x0a;8. 命名规则（如&quot;Game LAN&quot;），完成" FontSize="12" Foreground="#FF64B8FF" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF111930" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                                        <TextBlock Text="⚠️ 重要提示：&#x0a;• 如果关闭防火墙测试能联机，说明是防火墙问题&#x0a;• 建议配置防火墙规则，而不是关闭防火墙&#x0a;• 确保所有参与联机的电脑都配置了防火墙" FontSize="12" Foreground="#FFF57C00" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <!-- 第五部分：常见问题 -->
                            <GroupBox Header="❓ 第五部分：常见问题" Foreground="#FFFFFFFF" Background="#FF111930" BorderBrush="#FF3C4A5C" Padding="12" Margin="0,8">
                                <StackPanel>
                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="Q1: 找不到对方的房间？" FontWeight="Bold" Foreground="#FF64B8FF" FontSize="13" Margin="0,0,0,5"/>
                                            <TextBlock Text="答：&#x0a;• 检查是否在同一网络&#x0a;• 确认防火墙已配置&#x0a;• 检查 IP 地址是否正确&#x0a;• 确认游戏版本一致&#x0a;• 尝试直接输入 IP 加入" FontSize="12" Foreground="#FFB4BED6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FF202D55" CornerRadius="6" Padding="10" Margin="0,3">
